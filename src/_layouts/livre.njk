---
layout: base
---

<div data-pagefind-body data-pagefind-filter="section: Livres" class="region wrapper flow prose" style="--region-space-top: var(--space-xl-2xl)">
  <h1 class="gradient-text">Présentation du livre {{ title }}</h1>

  <h2>Fiche technique</h2>
<p>Date de commercialisation : {{page.date.toLocaleString( undefined, { year: 'numeric' })}}
<p>Nombre de pages : {{nombre_de_pages}} </p>
<p>Prix en euro : {{prix}} </p>
<p>Editeur : <a href="{{ edition_lie }}">{{ edition_nom }}</a> </p>
<div>

    {% include 'partials/livre3D.njk' %}
  <div data-pagefind-ignore>
      {{ content | lettrine | safe }}
  </div>
  </div>

  {% if critiques %}
    {% set headingLevel = "h3" %}
    {% include 'partials/commentaires.njk' %}
  {% endif %}

<div class="flow prose">
<a class="button" href="{{liens_achat}}">Soutenez moi en achetant ce livre</a>
</div>
</div>
<style>

@layer global {
  h1 {
    font-size: var(--size-step-4) !important;
  }
}
    p.author_cr {
        text-align: right;
    }

    .image-left {
      float: left;
      margin-right: 15px;
    }

@media (min-width: 600px) {
  img {
    width: 30vw;
    height: auto;
  }
}
</style>
