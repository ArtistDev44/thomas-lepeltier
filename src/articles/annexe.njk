---
title: "Liste des articles publiés"
date: Last Modified
layout: "annexe.njk"
permalink: "/articles/index.html"
---

<h2>Rangés chronologiquement</h2>
<hr>

<div class="cards-grid">
  <custom-masonry>
    {%- for article in collections.article | reverse -%}

      {# --- LOGIQUE DE LIEN --- #}
      {# On définit le lien : externe d'abord, sinon interne, sinon l'URL d'Eleventy #}
      {% set targetUrl = article.data.externalLink or article.data.internalLink or article.url %}

      {# On vérifie si c'est un lien externe pour le comportement du navigateur #}
      {% set isExternal = article.data.externalLink | length > 0 %}

      <custom-card>
        {# Slot Headline (Titre) - Utilise le lien dynamique #}
        <h3 slot="headline">
          <a href="{{ targetUrl }}" {% if isExternal %}target="_blank" rel="noopener noreferrer"{% endif %}>
            {{ article.data.title }}
          </a>
        </h3>
        {# Image de l'article via le shortcode Eleventy #}
        {% image article.data.imageUrl, "Première page de mon article " + article.data.title %}

        {# Slot Date #}
        <span slot="date">
          {{ article.date.toLocaleString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' }) }}
        </span>

        {# Slot Tag #}
        {%- for tag in article.data.tags -%}
          {%- if tag != "article" -%}
            <a href="/tags/{{ tag | slugify }}" slot="tag" class="button" style="width: 20vw; height:auto;">
              {{ tag }}
            </a>
          {%- endif -%}
        {%- endfor -%}

        {# Slot Headline (Titre) - Utilise le lien dynamique #}
        <h3 slot="headline">
          <a href="{{ targetUrl }}" {% if isExternal %}target="_blank" rel="noopener noreferrer"{% endif %}>
            {{ article.data.title }}
          </a>
        </h3>
      </custom-card>
    {%- endfor -%}
  </custom-masonry>
</div>
<style>
h3 {
    --flow-space: 1.3rem;
}
img {
    margin-top: 3rem;
}
</style>
