---
fontDisplay: "'Times New Roman', Big Caslon" # needed created in local development, font must be installed on your system.
fontBody: "'Big Caslon', Times New Roman" # needed created in local development, font must be installed on your system.
title: "Compte rendu du livre"
background: '#ff922b'
text: '#161616'
siteUrl: 'thomas.lepeltier.free.fr'
pagination:
  data: collections.allPosts
  size: 1
  alias: post
permalink: '/assets/og-images/{{ post.data.title | slugify }}-preview.svg'
eleventyExcludeFromCollections: true
---

<svg
  width="1200"
  height="630"
  viewBox="0 0 1200 630"
  version="1.1"
  xmlns="http://www.w3.org/2000/svg"
  xmlns:xlink="http://www.w3.org/1999/xlink"
>
  {% set titleInLines = title | splitlines(12) %}
  {% set numberOfLines = titleInLines.length %}
  {% if numberOfLines == 1 %}
    {% set verticalStartingPoint = 340 %}
    {% elseif numberOfLines == 2 %}
    {% set verticalStartingPoint = 290 %}
    {% elseif numberOfLines == 3 %}
    {% set verticalStartingPoint = 250 %}
    {% elseif numberOfLines == 4 %}
    {% set verticalStartingPoint = 210 %}
    {% elseif numberOfLines == 5 %}
    {% set verticalStartingPoint = 170 %}
  {% endif %}

  <rect id="bg" width="100%" height="100%" opacity="1" fill="{{ background }}" />

  <!-- date -->
  <text
    font-family="{{ fontBody }}, sans-serif"
    font-size="22"
    font-weight="700"
    fill="{{ text }}"
    letter-spacing="-1"
  >
    <tspan x="100" y="{{ verticalStartingPoint - 120 }}">
      {{ post.date | formatDate('DD / MM / YYYY') }}
    </tspan>
  </text>

  <!-- title -->
  <text
    id="text"
    font-family="{{ fontDisplay }}, sans-serif"
    font-size="100"
    font-weight="900"
    fill="{{ text }}"
    letter-spacing="-3"
  >
    {% for line in titleInLines %}
      <tspan x="100" y="{{ verticalStartingPoint - 20 + loop.index0 * 85 }}"> {{ line }} </tspan>
    {% endfor %}
  </text>

  <!-- url -->
  <text
    font-family="{{ fontBody }}, sans-serif"
    font-size="22"
    font-weight="500"
    fill="{{ text }}"
    letter-spacing="-0.5"
  >
    <tspan x="100" y="580">{{ siteUrl }}</tspan>
  </text>

  <!-- tag -->
  <text
    <!--font-family="{{ fontBody }}, sans-serif"
    font-size="18"
    font-weight="500"
    fill="{{ text }}"
    letter-spacing="-0.5"
  >
    <tspan x="160" y="500">{{ post.data.tags }}</tspan>
  </text>-->

  <!--TEST TAG-->
  <!-- tag -->
  <!--{% set filteredTags = post.data.tags | reject("equalto", "posts") | reject("equalto", "rapports") | list %}
  <text
    font-family="{{ fontBody }}, sans-serif"
    font-size="18"
    font-weight="500"
    fill="{{ text }}"
    letter-spacing="-0.5"
  >
    {% for tag in filteredTags %}
      <tspan x="{{ 100 + (loop.index0 * 100) }}" y="500">{{ tag }}</tspan>
    {% endfor %}
  </text>-->

  <!-- tag -->
  {% set filteredTags = post.data.tags | reject("equalto", "posts") | reject("equalto", "rapports") | list %}

  {% for tag in filteredTags %}
    {% set tagX = 160 + (loop.index0 * 500) %}
    <rect
      x="{{ tagX - 10 }}"
      y="482"
      width="{{ tag | length * 10 + 20 }}"
      height="28"
      fill="#161616"
      rx="4"
    />
    <text
      font-family="{{ fontBody }}, sans-serif"
      font-size="18"
      font-weight="500"
      fill="#ffffff"
      letter-spacing="-0.5"
    >
      <tspan x="{{ tagX }}" y="500">{{ tag }}</tspan>
    </text>
  {% endfor %}

  <!--image-->
  <defs>
    <clipPath id="imageClip">
      <rect x="800" y="0" width="390" height="630"/>
    </clipPath>
  </defs>

  <image
    x="800"
    y="0"
    width="390"
    height="630"
    href="{{ post.data.imageUrl | toBase64 }}"
    preserveAspectRatio="xMidYMid meet"
    clip-path="url(#imageClip)"
  />

<image
  href="{{ '/assets/images/thomas/thomas-profile.webp' | toBase64 }}"
  x="550"
  y="300"
  width="350"
  height="350"
/>

  <!-- sitename -->
  <text
    font-family="{{ fontDisplay }}, sans-serif"
    font-size="26"
    font-weight="950"
    fill="{{ text }}"
    letter-spacing="-0.5"
  >
    <tspan x="110" y="420">Par {{ meta.siteName | upper }}</tspan>
  </text>

<!-- pages/documents icon -->
<g transform="translate(60, -70) matrix(3.0106036,0,0,3.0106036,-1.7439471,-0.53191468)">
  <path
    fill="none"
    d="M104,36H56A12,12,0,0,0,44,48V208a12,12,0,0,0,12,12h48a12,12,0,0,0,12-12V48A12,12,0,0,0,104,36ZM52,76h56V180H52Zm4-32h48a4,4,0,0,1,4,4V68H52V48A4,4,0,0,1,56,44Zm48,168H56a4,4,0,0,1-4-4V188h56v20A4,4,0,0,1,104,212Zm123.74-16.62L194.55,37.57a12,12,0,0,0-14.25-9.3L133.49,38.32a12.1,12.1,0,0,0-9.23,14.3l33.19,157.81a12,12,0,0,0,14.25,9.3l46.81-10.06h0A12.08,12.08,0,0,0,227.74,195.38Zm-83.21-85.27,54.63-11.73,15,71.07-54.63,11.74Zm-6.64-31.56,54.64-11.74,5,23.74-54.64,11.73Zm-2.71-32.4L182,36.09a4,4,0,0,1,.84-.09,3.94,3.94,0,0,1,2.14.64,4,4,0,0,1,1.76,2.58L190.88,59,136.24,70.72,132.09,51A4.07,4.07,0,0,1,135.18,46.15Zm81.65,155.7L170,211.91a4,4,0,0,1-3-.55,4,4,0,0,1-1.76-2.58L161.12,189l54.64-11.73L219.91,197A4.07,4.07,0,0,1,216.83,201.85Z" stroke="black" stroke-opacity="0.1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"  />
</g>
</svg>
