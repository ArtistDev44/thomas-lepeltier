---
title: "Liste des livres publiés"
date: Last Modified
layout: "annexe.njk"
permalink: "/livres/index.html"
---

<h2>Rangés chronologiquement</h2>
<hr>

<div class="cards-grid">
  <custom-masonry>
    {%- for livre in collections.livre | reverse -%}

      {# --- LOGIQUE DE LIEN --- #}
      {# On définit le lien : externe d'abord, sinon interne, sinon l'URL d'Eleventy #}
      {% set targetUrl = livre.data.externalLink or livre.data.internalLink or livre.url %}

      {# On vérifie si c'est un lien externe pour le comportement du navigateur #}
      {% set isExternal = livre.data.externalLink | length > 0 %}

      <custom-card>
        {# Slot Headline (Titre) - Utilise le lien dynamique #}
        <p slot="headline">
          <a href="{{ targetUrl }}" {% if isExternal %}target="_blank" rel="noopener noreferrer"{% endif %}>
            {{ livre.data.title }}
          </a>
        </p>
        {# Image de l'livre via le shortcode Eleventy #}
        {% image livre.data.imageUrl, "Première page de mon livre " + livre.data.title %}

        {# Slot Date #}
        <span slot="date">
          {{ livre.date.toLocaleString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' }) }}
        </span>

        {# Slot Tag #}
        {%- for tag in livre.data.tags -%}
          {%- if tag != "livre" -%}
            <a href="/tags/{{ tag | slugify }}" slot="tag" class="button" style="width: 20vw; height:auto;">
              {{ tag }}
            </a>
          {%- endif -%}
        {%- endfor -%}

        {# Slot Headline (Titre) - Utilise le lien dynamique #}
        <p slot="headline">
          <a href="{{ targetUrl }}" {% if isExternal %}target="_blank" rel="noopener noreferrer"{% endif %}>
            {{ livre.data.title }}
          </a>
        </p>
      </custom-card>
    {%- endfor -%}
  </custom-masonry>
</div>
<style>
h3 {
    --flow-space: 1.3rem;
}
img {
    margin-top: 3rem;
}
</style>
