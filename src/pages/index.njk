            /* ─── Conteneur principal ─── */
        .hero-parallax {
          position: relative;
          overflow: hidden; /* indispensable pour masquer le débordement de l'image */
          min-height: 100svh;
          display: grid;
          place-items: center;
        }

        /* ─── Calque image (élément porteur) ─── */
        .hero-parallax__bg {
          position: absolute;
          inset: 0%; /* surclasse la zone visible pour que l'image ait de la marge de défilement */
          z-index: 0;
        }

        /* ─── L'image elle-même ─── */
        .hero-parallax__img {
          display: block;
          width: 100%;
          height: 100%;
          object-fit: cover;
          object-position: center;

          /* ✦ Le cœur du parallax CSS ✦ */
          will-change: transform;
          transform: translateY(0);
          animation: parallax-scroll linear both;

          /* Lie l'animation à la progression du scroll dans le viewport */
          animation-timeline: view();
          animation-range: entry 0% exit 100%;
        }

        @keyframes parallax-scroll {
          from { transform: translateY(-15%); }
          to   { transform: translateY(15%); }
        }

        /* ─── Contenu au-dessus de l'image ─── */
        .hero-parallax__content {
          position: relative;
          z-index: 1;
        }

        /* ─── Overlay sombre facultatif pour la lisibilité ─── */
        .hero-parallax__bg::after {
          content: "";
          position: absolute;
          inset: 0;
          z-index: 1;
        }

        </style>
